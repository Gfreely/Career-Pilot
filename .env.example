# 求职面试助手 - 环境变量配置模板
# 请将此文件复制为 .env（或直接在系统中设置以下环境变量）
# 注意: .env 文件本身已在 .gitignore 中被忽略，不会被提交

# ============================================================
# SiliconFlow API Key (必填)
# 用于驱动所有 LLM 推理与 Embedding 接口调用
# 获取地址: https://siliconflow.cn
# ============================================================
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ============================================================
# Milvus 向量数据库连接地址 (可选，默认本地)
# 如果使用 Zilliz Cloud 或远端 Milvus，修改此地址
# ============================================================
# MILVUS_URI=http://127.0.0.1:19530

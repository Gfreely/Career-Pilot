# ============================================================
#  XinghuoLLM .gitignore
#  最后更新: 2026-04-18
# ============================================================


# ============================================================
#  Python 环境与编译产物
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# 虚拟环境
.venv/
venv/
env/
ENV/
.env.local

# setuptools / egg
*.egg
*.egg-info/
dist/
build/
.eggs/

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy / type checking
.mypy_cache/
.dmypy.json


# ============================================================
#  本地配置与敏感信息（API Key 等）
# ============================================================
.env
*.env
config_local.py
secrets.yaml
magic-pdf.json


# ============================================================
#  项目私有数据 - data/ 目录
#  包含原始 PDF、MD 知识库、向量数据库、简历、评估结果等
# ============================================================
data/
# src 内部的 data 子目录（含用户简历等临时文件）
src/data/
# 同时忽略根目录下的 data.zip 压缩归档
data.zip


# ============================================================
#  对话历史记录 - conversations/ 目录
#  仅忽略内部 JSON 文件，保留目录本身（通过 .gitkeep）
# ============================================================
conversations/*.json
conversations/**/*.json
# 如需保留目录，请在该目录下放一个空的 .gitkeep 文件


# ============================================================
#  运行日志 - logs/ 目录
#  忽略日志文件，保留目录本身
# ============================================================
logs/*.log
logs/**/*.log


# ============================================================
#  大语言模型权重文件 - model/ 目录
# ============================================================
model/


# ============================================================
#  证据存档 - evidence/ 目录
# ============================================================
evidence/


# ============================================================
#  本地规则配置 - .rules/ 目录
# ============================================================
.rules/


# ============================================================
#  IDE 工具配置
# ============================================================

# JetBrains (PyCharm 等)
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/
*.code-workspace

# Vim / Note 残留
*.swp
*.swo
*~


# ============================================================
#  操作系统产生的文件
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db


# ============================================================
#  临时打包归档
# ============================================================
*.zip
*.tar.gz
*.rar
*.7z


# ============================================================
#  Jupyter Notebook 缓存（如使用）
# ============================================================
.ipynb_checkpoints/
*.ipynb_checkpoints/


# ============================================================
#  用户画像本地文件（含个人信息）
# ============================================================
user_profile.yaml
